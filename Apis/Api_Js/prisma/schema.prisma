generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model configuracion_firmas {
  configuracion_firma_id        Int            @id(map: "pk_configuracion_firma") @default(autoincrement())
  configuracion_firma_version   String         @default("X.509", map: "DF__configura__confi__778AC167") @db.NVarChar(100)
  configuracion_firma_serie     String         @db.NVarChar(100)
  configuracion_firma_algoritmo String         @default("rsa", map: "DF__configura__confi__787EE5A0") @db.NVarChar(100)
  configuracion_firma_emisor    String         @db.NVarChar(300)
  configuracion_firma_cn        String         @db.NVarChar(300)
  configuracion_firma_o         String         @db.NVarChar(100)
  configuracion_firma_ou        String         @db.NVarChar(100)
  configuracion_firma_i         String         @db.NVarChar(100)
  configuracion_firma_st        String         @db.NVarChar(100)
  configuracion_firma_c         String         @db.NVarChar(100)
  firma_id_fk                   Int
  version_firma_id_fk           Int
  firmas                        firmas         @relation(fields: [firma_id_fk], references: [firma_id], onUpdate: NoAction, map: "fk_firma_en_configuracion_firma")
  version_firmas                version_firmas @relation(fields: [version_firma_id_fk], references: [version_firma_id], onUpdate: NoAction, map: "fk_version_firma")
}

model contrasenas_firmas {
  contrasena_firma_id    Int    @id(map: "pk_contrasena_firma") @default(autoincrement())
  contrasena_firma_valor String
  firma_id_fk            Int    @unique(map: "UQ__contrase__2872F92C443474CD")
  firmas                 firmas @relation(fields: [firma_id_fk], references: [firma_id], onUpdate: NoAction, map: "fk_firma_en_contrasena_firma")
}

model correos_enviados {
  correo_enviado_id      Int                @id(map: "pk_correo_usado") @default(autoincrement())
  correo_enviado_fecha   DateTime
  correo_enviado_cuerpo  String             @db.NVarChar(Max)
  usuario_id_fk          Int
  tipo_correo_id_fk      Int
  plantilla_correo_id_fk Int
  plantillas_correos     plantillas_correos @relation(fields: [plantilla_correo_id_fk], references: [plantilla_correo_id], onUpdate: NoAction, map: "fk_plantilla_correo_en_correo_enviado")
  tipos_correos          tipos_correos      @relation(fields: [tipo_correo_id_fk], references: [tipo_correo_id], onUpdate: NoAction, map: "fk_tipo_correo_en_correo_enviado")
  usuarios               usuarios           @relation(fields: [usuario_id_fk], references: [usuario_id], onUpdate: NoAction, map: "fk_usuario_en_correo_enviado")
}

model datos_certificados {
  dato_certificado_id                                 Int                  @id(map: "pk_datos_certificados") @default(autoincrement())
  dato_certificado_numero                             Int
  dato_certificado_version                            String               @db.NVarChar(100)
  dato_certificado_serial                             String               @db.NVarChar(200)
  dato_certificado_oid                                String               @db.NVarChar(200)
  dato_certificado_fecha_creacion                     DateTime             @db.Date
  dato_certificado_fecha_vencimiento                  DateTime             @db.Date
  dato_certificado_estado                             Boolean
  dato_certificado_editor                             String               @db.NVarChar(Max)
  dato_certificado_sujeto                             String               @db.NVarChar(Max)
  dato_certificado_causa_estado                       String               @db.NVarChar(Max)
  dato_certificado_fecha_uso                          DateTime?            @db.Date
  dato_certificado_validacion_vencimiento_estado      Boolean
  dato_certificado_validacion_vencimiento_descripcion String               @db.NVarChar(Max)
  dato_certificado_validacion_uso_estado              Boolean?
  dato_certificado_validacion_uso_descripcion         String               @db.NVarChar(Max)
  dato_certificado_validacion_hash_estado             Boolean
  dato_certificado_validacion_hash_descripcion        String               @db.NVarChar(Max)
  dato_certificado_validacion_integridad_estado       Boolean
  dato_certificado_validacion_integridad_descripcion  String               @db.NVarChar(Max)
  documento_validado_fk                               Int
  documentos_validados                                documentos_validados @relation(fields: [documento_validado_fk], references: [documento_validado_id], onUpdate: NoAction, map: "fk_documento_validado_en_dato_certificado")
}

model documentos_validados {
  documento_validado_id              Int                   @id(map: "pk_documento_validado") @default(autoincrement())
  documento_validado_ubicacion       String                @db.NVarChar(Max)
  documento_validado_estado          Boolean?
  documento_validado_nombre          String                @db.NVarChar(Max)
  documento_validado_causa_estado    String?               @db.NVarChar(Max)
  documento_validado_total_firmas    Int?
  documento_validado_firmas_vencidas Int?
  documento_validado_tipo            String                @db.NVarChar(30)
  peticion_validacion_id_fk          Int
  datos_certificados                 datos_certificados[]
  peticiones_validacion              peticiones_validacion @relation(fields: [peticion_validacion_id_fk], references: [peticion_validacion_id], onUpdate: NoAction, map: "fk_peticion_validacion_en_documento_validado")
}

model firmas {
  firma_id                Int                    @id(map: "pk_firma") @default(autoincrement())
  firma_pub               String?                @db.NVarChar(Max)
  firma_crt               String?                @db.NVarChar(Max)
  firma_p12               String                 @db.NVarChar(Max)
  firma_fecha_creacion    DateTime
  firma_fecha_vencimiento DateTime
  firma_correo_asociado   String                 @db.NVarChar(Max)
  firma_ubicacion         String                 @db.NVarChar(Max)
  firma_estado            Boolean
  usuario_id_fk           Int
  tipo_firma_id_fk        Int
  configuracion_firmas    configuracion_firmas[]
  contrasenas_firmas      contrasenas_firmas?
  documentos_firmas       documentos_firmas[]
  tipo_firmas             tipo_firmas            @relation(fields: [tipo_firma_id_fk], references: [tipo_firma_id], onUpdate: NoAction, map: "fk_tipo_firma_en_firma")
  usuarios                usuarios               @relation(fields: [usuario_id_fk], references: [usuario_id], onUpdate: NoAction, map: "fk_usuario_en_firma")
  llaves_privadas         llaves_privadas?
  version_firmas          version_firmas[]
}

model llaves_privadas {
  llave_id    Int    @id(map: "pk_llave") @default(autoincrement())
  llave_valor String @db.NVarChar(Max)
  firma_id_fk Int    @unique(map: "UQ__llaves_p__2872F92C358163C1")
  firmas      firmas @relation(fields: [firma_id_fk], references: [firma_id], onUpdate: NoAction, map: "fk_firmas_en_llave_privada")
}

model peticiones_validacion {
  peticion_validacion_id     Int                    @id(map: "pk_peticion_validacion") @default(autoincrement())
  peticion_validacion_fecha  DateTime               @db.DateTime
  peticion_validacion_nombre String                 @db.NVarChar(300)
  usuario_id_fk              Int
  documentos_validados       documentos_validados[]
  usuarios                   usuarios               @relation(fields: [usuario_id_fk], references: [usuario_id], onUpdate: NoAction, map: "fk_usuario_en_peticion_validacion")
  reportes                   reportes[]
}

model plantillas_correos {
  plantilla_correo_id          Int                @id(map: "pk_plantilla_correo") @default(autoincrement())
  plantilla_correo_nombre      String             @unique(map: "UQ__plantill__88EDD0D731863D3E") @db.VarChar(50)
  plantilla_correo_descripcion String             @db.NVarChar(300)
  plantilla_correo_contenido   String             @db.NVarChar(Max)
  correos_enviados             correos_enviados[]
}

model reportes {
  reporte_id                Int                   @id(map: "pk_reporte") @default(autoincrement())
  reporte_ubicacion         String                @db.NVarChar(Max)
  reporte_fecha             DateTime
  reporte_existencia        Boolean               @default(true, map: "DF__reportes__report__05D8E0BE")
  peticion_validacion_id_fk Int
  tipo_reporte_id_fk        Int
  peticiones_validacion     peticiones_validacion @relation(fields: [peticion_validacion_id_fk], references: [peticion_validacion_id], onUpdate: NoAction, map: "fk_peticion_validacion_en_reporte")
  tipo_reportes             tipo_reportes         @relation(fields: [tipo_reporte_id_fk], references: [tipo_reporte_id], onUpdate: NoAction, map: "fk_tipo_reporte_en_reporte")
}

model roles {
  rol_id            Int                 @id(map: "pk_rol") @default(autoincrement())
  rol_nombre        String              @unique(map: "UQ__roles__4900B49AD3D9F2CB") @db.VarChar(50)
  rol_descripcion   String              @db.NVarChar(300)
  roles_disponibles roles_disponibles[]
}

model sesiones {
  sesion_id                  Int      @id(map: "pk_sesion") @default(autoincrement())
  sesion_fecha               DateTime
  sesion_dispositivo         String   @db.VarChar(Max)
  sesion_ip                  String   @db.NVarChar(25)
  sesion_autenticacion_token String   @db.NVarChar(25)
  sesion_token               String   @db.NVarChar(Max)
  usuario_id_fk              Int
  usuarios                   usuarios @relation(fields: [usuario_id_fk], references: [usuario_id], onUpdate: NoAction, map: "fk_usuario_en_inicio_sesion")
}

model tipo_firmas {
  tipo_firma_id          Int      @id(map: "pk_tipo_firma") @default(autoincrement())
  tipo_firma_nombre      String   @unique(map: "UQ__tipo_fir__1557963A980A1E63") @db.NVarChar(30)
  tipo_firma_descripcion String   @db.NVarChar(300)
  firmas                 firmas[]
}

model tipo_reportes {
  tipo_reporte_id          Int        @id(map: "pk_tipo_reporte") @default(autoincrement())
  tipo_reporte_nombre      String     @unique(map: "UQ__tipo_rep__910808BD7E2623D5") @db.VarChar(50)
  tipo_reporte_descripcion String     @db.NVarChar(300)
  reportes                 reportes[]
}

model tipos_correos {
  tipo_correo_id          Int                @id(map: "pk_tipo_correo") @default(autoincrement())
  tipo_correo_nombre      String             @unique(map: "UQ__tipos_co__AD329B0ADA357AC1") @db.VarChar(50)
  tipo_correo_descripcion String             @db.NVarChar(300)
  correos_enviados        correos_enviados[]
}

model usuarios {
  usuario_id               Int                     @id(map: "pk_usuario") @default(autoincrement())
  usuario_nombre           String                  @unique(map: "UQ__usuarios__220D44A2CDF6011A") @db.NVarChar(50)
  usuario_nombre_real      String                  @db.NVarChar(200)
  usuario_documento        BigInt                  @unique(map: "UQ__usuarios__A009CC114BF8B999")
  usuario_email            String                  @unique(map: "UQ__usuarios__1C1E91042D69214A") @db.NVarChar(500)
  usuario_email_secundario String                  @db.NVarChar(Max)
  usuario_pais             String                  @db.NVarChar(100)
  usuario_habilitado       Boolean
  usuario_estado           Boolean
  medio_creacion_id_fk     Int
  correos_enviados         correos_enviados[]
  firmas                   firmas[]
  logs                     logs[]
  peticiones_validacion    peticiones_validacion[]
  roles_disponibles        roles_disponibles[]
  sesiones                 sesiones[]
  medios_creacion_usuario  medios_creacion_usuario @relation(fields: [medio_creacion_id_fk], references: [medios_creacion_id], onUpdate: NoAction, map: "fk_medio_creacion_en_usuario")
}

model version_firmas {
  version_firma_id     Int                    @id(map: "pk_version_firma") @default(autoincrement())
  version_firma        String                 @db.NVarChar(100)
  firma_id_fk          Int
  configuracion_firmas configuracion_firmas[]
  firmas               firmas                 @relation(fields: [firma_id_fk], references: [firma_id], onUpdate: NoAction, map: "fk_firma_en_version_firma")
}

model documentos {
  documento_id           Int                 @id(map: "pk_documento") @default(autoincrement())
  documento_ubicacion    String              @db.NVarChar(Max)
  documento_estado       Boolean
  documento_fecha        DateTime
  documento_token_acceso String?             @db.NVarChar(Max)
  documento_permiso      Boolean
  tipo_documento_id_fk   Int
  estado_documento_id_fk Int
  estado_documentos      estado_documentos   @relation(fields: [estado_documento_id_fk], references: [estado_documento_id], onUpdate: NoAction, map: "fk_estado_documento_en_documento")
  tipo_documentos        tipo_documentos     @relation(fields: [tipo_documento_id_fk], references: [tipo_documento_id], onUpdate: NoAction, map: "fk_tipo_documento_en_documento")
  documentos_firmas      documentos_firmas[]
}

model documentos_firmas {
  documento_firma_id    Int        @id(map: "pk_documento_firma") @default(autoincrement())
  documento_firma_fecha DateTime
  firma_id_fk           Int
  documento_id_fk       Int
  documentos            documentos @relation(fields: [documento_id_fk], references: [documento_id], onUpdate: NoAction, map: "fk_documento_en_documento_firma")
  firmas                firmas     @relation(fields: [firma_id_fk], references: [firma_id], onUpdate: NoAction, map: "fk_firma_en_documento_firma")
}

model estado_documentos {
  estado_documento_id          Int          @id(map: "pk_estado_documento") @default(autoincrement())
  estado_documento             String       @db.NVarChar(30)
  estado_documento_descripcion String       @db.NVarChar(Max)
  documentos                   documentos[]
}

model logs {
  log_id                   Int        @id(map: "pk_log") @default(autoincrement())
  log_titulo               String     @db.NVarChar(30)
  log_descripcion_base     String     @db.NVarChar(Max)
  log_descripcion_completa String     @db.NVarChar(Max)
  log_fecha                DateTime
  log_usuario_bd           String     @db.NVarChar(Max)
  log_ip_peticion          String     @db.NVarChar(30)
  log_dispositivo_peticion String     @db.NVarChar(100)
  log_tipo_id_fk           Int
  usuario_id_fk            Int?
  tipos_logs               tipos_logs @relation(fields: [log_tipo_id_fk], references: [tipo_log_id], onUpdate: NoAction, map: "fk_tipo_log_en_log")
  usuarios                 usuarios?  @relation(fields: [usuario_id_fk], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_en_log")
}

model medios_creacion_usuario {
  medios_creacion_id          Int        @id(map: "pk_medios_creacion") @default(autoincrement())
  medios_creacion             String     @unique(map: "UQ__medios_c__C3F27786203EC04C") @db.VarChar(50)
  medios_creacion_descripcion String     @db.NVarChar(300)
  usuarios                    usuarios[]
}

model roles_disponibles {
  rol_disponible_id Int      @id(map: "pk_rol_disponible") @default(autoincrement())
  usuario_id_fk     Int
  rol_id_fk         Int
  roles             roles    @relation(fields: [rol_id_fk], references: [rol_id], onUpdate: NoAction, map: "fk_rol_en_rol_disponible")
  usuarios          usuarios @relation(fields: [usuario_id_fk], references: [usuario_id], onUpdate: NoAction, map: "fk_usuario_en_rol_disponible")
}

model sysdiagrams {
  name         String @db.NVarChar(128)
  principal_id Int
  diagram_id   Int    @id(map: "PK__sysdiagr__C2B05B611DFA82E3") @default(autoincrement())
  version      Int?
  definition   Bytes?

  @@unique([principal_id, name], map: "UK_principal_name")
}

model tipo_documentos {
  tipo_documento_id          Int          @id(map: "pk_tipo_documento") @default(autoincrement())
  tipo_documento             String       @db.NVarChar(30)
  tipo_documento_descripcion String       @db.NVarChar(Max)
  documentos                 documentos[]
}

model tipos_logs {
  tipo_log_id          Int    @id(map: "pk_tipo_log") @default(autoincrement())
  tipo_log_nombre      String @db.NVarChar(30)
  tipo_log_descripcion String @db.NVarChar(Max)
  logs                 logs[]
}
